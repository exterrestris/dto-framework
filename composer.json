{
  "name": "exterrestris/dto-framework",
  "description": "A framework for validation, serialization and comparison of immutable data transfer objects",
  "require": {
    "php": ">=8.2",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5.0"
  },
  "autoload": {
    "psr-4": {
      "Exterrestris\\DtoFramework\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Exterrestris\\DtoFramework\\Tests\\": "tests/",
      "Exterrestris\\DtoFramework\\Tests\\Mocks\\": "tests/mocks/"
    }
  },
  "suggest": {
    "monolog/monolog": "^3.0.0"
  }
}
